# OpenAI API Key (required for chat and transcription)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Vercel Blob Storage Token (required for audio transcription)
# Automatically provided by Vercel when you create a Blob store
# For local development, get it from: https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# Supabase project URL (required when using Supabase DAOs)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable key (preferred key name with new Supabase API key scheme)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# Optional backward-compatible key name used in some dashboards/setups
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_publishable_key_here

# Optional legacy key name (old anon-key naming)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
